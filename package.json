{
  "name": "irecord",
  "version": "0.9.1",
  "description": "你说我记 - 本地语音识别转写工具",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:win:portable": "npm run build && electron-builder --dir && node -e \"const v=require('./package.json').version,fs=require('fs'),p='release/'+v;fs.existsSync(p+'/win-unpacked')&&fs.renameSync(p+'/win-unpacked',p+'/iRecord-'+v+'-win-x64')\""
  },
  "build": {
    "appId": "com.irecord.app",
    "productName": "iRecord",
    "executableName": "irecord",
    "npmRebuild": false,
    "electronVersion": "41.2.1",
    "directories": {
      "output": "release/${version}"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "!resources/**/*"
    ],
    "extraResources": [
      {
        "from": "src/main/engine/asr-process.js",
        "to": "asr-process.js"
      },
      {
        "from": "src/main/keywords/extract.js",
        "to": "extract.js"
      },
      {
        "from": "resources/ffmpeg",
        "to": "resources/ffmpeg"
      },
      {
        "from": "resources/models/silero-vad",
        "to": "resources/models/silero-vad"
      },
      {
        "from": "resources/models/speaker-diarization",
        "to": "resources/models/speaker-diarization"
      },
      {
        "from": "resources/models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17",
        "to": "resources/models/sherpa-onnx-sense-voice-zh-en-ja-ko-yue-2024-07-17"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sherpa-onnx-node/**",
      "node_modules/nodejieba/**",
      "node_modules/sql.js/**"
    ]
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@tiptap/extension-bubble-menu": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "antd": "^6.3.6",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^1.8.0",
    "nodejieba": "^3.5.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sherpa-onnx-node": "^1.12.38",
    "sql.js": "^1.14.1",
    "tar": "^7.5.15",
    "unbzip2-stream": "^1.4.3",
    "wavesurfer.js": "^7.12.6",
    "zustand": "^5.0.12"
  }
}
